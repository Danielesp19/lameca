# ── Frontend (Vercel) — variables de producción ──
# Cópialas en Vercel → Project → Settings → Environment Variables (entorno Production).
# Reemplaza la URL por la real de tu backend en Render (la ves tras crear el servicio).

# URL interna del backend Laravel en Render. La usan los rewrites de Next
# (/api-menu → backend/api, /menu-storage → backend/storage) y el fetch SSR.
BACKEND_URL=https://coffeeclub-api.onrender.com
MENU_API_INTERNAL=https://coffeeclub-api.onrender.com/api

# El navegador la usa SOLO para subir archivos del admin directo al backend
# (salta el proxy para evitar errores 413). Requiere que esta URL del frontend
# esté en CORS_ALLOWED_ORIGINS del backend en Render.
NEXT_PUBLIC_BACKEND_URL=https://coffeeclub-api.onrender.com

# El resto de llamadas del navegador pasan por el proxy de Next (valor por defecto).
# No hace falta definirla salvo que quieras cambiar la ruta:
# NEXT_PUBLIC_MENU_API=/api-menu

# ── Panel admin del frontend ──
# El login (/api/admin-auth) valida ADMIN_PASSWORD y, si es correcto, entrega ADMIN_TOKEN
# al navegador, que lo envía como Bearer al backend.
ADMIN_PASSWORD=pon-una-clave-fuerte
# DEBE coincidir EXACTAMENTE con ADMIN_TOKEN del backend en Render:
ADMIN_TOKEN=mismo-token-que-en-render
