APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Local (desarrollo): SQLite por defecto, sin servidor.
DB_CONNECTION=sqlite

# Producción (Render): PostgreSQL. Render inyecta estos valores automáticamente
# vía el blueprint render.yaml (no los pongas a mano allí). Para correr Postgres
# en local, descomenta y ajusta:
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=coffeeclub
# DB_USERNAME=coffeeclub
# DB_PASSWORD=
# DB_SSLMODE=prefer

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ───────────────────────────────────────────────────────────────────────────────
# CoffeeClub / La Meca — config de la app (leída vía config/coffee.php)
# ───────────────────────────────────────────────────────────────────────────────

# Token del panel admin (Bearer). En producción: largo y aleatorio.
# Genéralo con:  php -r "echo bin2hex(random_bytes(32));"
ADMIN_TOKEN=coffee-admin-secret-2026

# Orígenes permitidos para CORS (coma-separados, sin barra final). OBLIGATORIO en prod
# para que el panel admin pueda subir imágenes directo al backend.
# Ej: CORS_ALLOWED_ORIGINS=https://carta.lameca.co,https://admin.lameca.co
CORS_ALLOWED_ORIGINS=

# Cloudflare Turnstile (CAPTCHA invisible). Vacío = deshabilitado.
TURNSTILE_SECRET=

# Tiempos de vida (minutos)
TABLE_SESSION_TTL_MINUTES=15
ORDER_TTL_MINUTES=45

# Máximo de pedidos activos (pending/seen) por mesa. 0 = sin límite.
MAX_ACTIVE_ORDERS_PER_TABLE=3

# Horario de atención "HH:MM-HH:MM" (hora Colombia). Vacío = siempre abierto.
# Fuera del rango no se aceptan pedidos ni llamadas al mesero. Soporta cruzar
# medianoche, p. ej. "18:00-02:00".
SERVICE_HOURS=
# COFFEE_TIMEZONE=America/Bogota

# Imágenes subidas: se reducen al lado máximo indicado y se convierten a WebP.
MAX_IMAGE_PX=1600
IMAGE_QUALITY=80

# Videos subidos: se recomprimen con FFmpeg (720p, H.264 CRF 30, sin audio).
# Si ffmpeg no está en el PATH del servidor, indica la ruta del binario:
# FFMPEG_PATH=/usr/bin/ffmpeg
# MAX_VIDEO_PX=720
# VIDEO_CRF=30

# ───────────────────────────────────────────────────────────────────────────────
# PRODUCCIÓN — checklist (NO dejar valores de dev):
#   APP_ENV=production
#   APP_DEBUG=false                  # nunca true en prod (filtra trazas/secretos)
#   APP_URL=https://api.tudominio.co
#   php artisan key:generate         # APP_KEY único por entorno
#   php artisan storage:link         # para servir imágenes en /storage
#   php artisan config:cache route:cache
#   Cron del scheduler:  * * * * * cd /ruta && php artisan schedule:run >> /dev/null 2>&1
# ───────────────────────────────────────────────────────────────────────────────
